{
  "manifest_version": 3,
  "name": "Browser Control",
  "version": "1.0.0",
  "description": "Production-grade browser automation bridge for AI agents. Enables navigation, clicking, typing, screenshots, DOM snapshots, and more through a local daemon.",
  "permissions": [
    "activeTab",
    "tabs",
    "tabGroups",
    "storage",
    "scripting",
    "webNavigation",
    "webRequest",
    "downloads",
    "pageCapture",
    "debugger",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Browser Control"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
